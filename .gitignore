# Node modules - ALWAYS IGNORE
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment variables - CRITICAL TO IGNORE (contain secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
backend/.env
backend/.env.*
.env.backup

# Build outputs
/build
/dist
/out
/backend/dist
/backend/build

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
backend/*.log
logs/
backend/logs/

